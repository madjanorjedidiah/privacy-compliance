# ───────────────────────────────────────────────────────────────────────────
# Privacy Compliance — environment variables (STANDALONE deployment)
#
# Copy to `.env` and fill in. Never commit the populated .env file.
# `./scripts/quickstart.sh` will do this copy and generate secrets for you.
#
# This file matches the default `docker-compose.yml`, which brings up its
# own Postgres + Redis + nginx. For the shared-infra variant
# (external Postgres / Redis / Nginx Proxy Manager) see the docstring at
# the top of `docker-compose.shared.yml`.
# ───────────────────────────────────────────────────────────────────────────

# -- Django -----------------------------------------------------------------
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=mydatacompliance.domainname,localhost,127.0.0.1,privacy_django,privacy_nginx
DJANGO_CSRF_TRUSTED_ORIGINS=https://mydatacompliance.domainname

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
APP_SECRET_KEY=replace-me-with-a-64-byte-random-value

# -- Database (Postgres container in the stack) -----------------------------
POSTGRES_DB=privacy_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# -- Cache / broker (Redis container in the stack) -------------------------
# Not normally edited — the compose file wires these up. Override only if
# you point at an external Redis (e.g. managed service).
# REDIS_URL=redis://redis:6379/4
# CELERY_BROKER_URL=redis://redis:6379/5
# CELERY_RESULT_BACKEND=redis://redis:6379/5

# -- TLS / nginx ports -----------------------------------------------------
# nginx terminates TLS inside the stack. Ports are 80 and 443 by default.
# Change if the host is already using them.
# HTTP_PORT=80
# HTTPS_PORT=443

# Set to 1 once you have a real domain + Let's Encrypt cert issued.
APP_ENABLE_HTTPS=0
APP_HSTS_SECONDS=31536000

# -- Logging ----------------------------------------------------------------
APP_LOG_LEVEL=INFO
APP_LOG_FORMAT=json                     # json | text

# -- Rate limiting ----------------------------------------------------------
APP_RATE_LIMIT_LOGIN=5/m
APP_RATE_LIMIT_SIGNUP=10/h

# -- Banner (flip to 0 once DPC registration + counsel review are done) -----
APP_PRIVATE_BETA=1

# -- Billing (always off for the community platform) -----------------------
APP_ENABLE_BILLING=0

# -- Email (SMTP — optional; leave blank for DEBUG console backend) --------
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DJANGO_DEFAULT_FROM_EMAIL=Privacy Compliance <no-reply@privacy.domain>
DJANGO_SERVER_EMAIL=ops@privacy.domain
DJANGO_ADMINS=Ops:ops@privacy.domain

# -- Bootstrap superuser (compose entrypoint runs createsuperuser if set) --
# Leave blank to skip. Use a strong password and ROTATE after first login.
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@privacy.domain
DJANGO_SUPERUSER_PASSWORD=

# -- Let's Encrypt (only used with --profile letsencrypt) ------------------
# Uncomment + fill in once your DNS points at this host.
# CERTBOT_DOMAIN=mydatacompliance.example.com
# CERTBOT_EMAIL=ops@privacy.domain
